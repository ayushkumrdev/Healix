# Healix environment TEMPLATE — copy to `.env` for direct Python runs
#   cp .env.example .env
#
# The real `.env` is gitignored. This template is committed so the set of
# supported variables (and their defaults) stays documented. None of these are
# secrets — they are configuration. If you ever add a real secret (API key,
# token), put it ONLY in `.env`, never here.
#
# PRECEDENCE — read before editing:
#   start_system.bat sets these same variables in the process environment
#   BEFORE launch. Services then call load_dotenv(), which does NOT override
#   variables already set. Therefore:
#     - Launched via start_system.bat -> the .bat values win; .env is ignored.
#     - Launched directly via python  -> .env values apply.
#   Keep .env in sync with start_system.bat so both paths behave identically.

# Model
BAYMAX_GGUF_MODEL_NAME=mistral-7b-instruct-v0.2.Q4_K_M.gguf
BAYMAX_GGUF_MODEL_DIR=artifacts
BAYMAX_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Generation
BAYMAX_FAST_MODE=true
BAYMAX_GEN_THREADS=12
BAYMAX_GEN_MAX_TOKENS=900
BAYMAX_GEN_MIN_TOKENS=60
BAYMAX_GEN_TOKENS=900
BAYMAX_GEN_SHORT_TOKENS=256
BAYMAX_GEN_CONTEXT=8192
BAYMAX_GEN_STREAM=true
BAYMAX_GEN_TEMP=0.4
BAYMAX_GEN_TOP_K=10
BAYMAX_GEN_TOP_P=0.9
BAYMAX_GEN_STYLE=abstractive
BAYMAX_CONTEXT_CHARS=400
BAYMAX_POST_ABSTRACT=0
BAYMAX_GENERATE_ALL=1
BAYMAX_NO_FALLBACKS=1

# Retrieval (kept in sync with start_system.bat)
BAYMAX_RERANKER=cross-encoder/ms-marco-MiniLM-L-6-v2
BAYMAX_RERANK_TOPN=50
BAYMAX_RERANK_BATCH=32
BAYMAX_RERANK_SKIP_THRESHOLD=0.86
BAYMAX_RAG_STRICT=0

# Explainability
BAYMAX_ENABLE_XAI=1

# Conversation memory (per-turn recall window; full history persists on disk)
BAYMAX_MEMORY_TURNS=10
BAYMAX_MEMORY_CHARS=2400

# Agentic Mixture-of-Experts routing (set 0 to disable / A-B test)
HEALIX_MOE=1

# Hybrid retrieval: dense (FAISS) + sparse (BM25) fused with RRF (0 to disable)
HEALIX_HYBRID=1
# HyDE query expansion + RAPTOR overview tree (fail-open if artifacts absent)
HEALIX_HYDE=1
HEALIX_RAPTOR=1
# HyDE only needs a plausible hypothetical for embedding — a small fast model
# keeps this pre-retrieval call ~3s instead of ~10s. Unset to reuse the main model.
HEALIX_HYDE_MODEL=qwen2.5:0.5b-instruct

# LLM backend: "ollama" uses the local Ollama server (skips the GGUF load).
# Leave BAYMAX_LLM_BACKEND empty to use the bundled llama.cpp/GGUF model instead.
BAYMAX_LLM_BACKEND=ollama
BAYMAX_OLLAMA_URL=http://localhost:11434
BAYMAX_OLLAMA_MODEL=qwen2.5:7b-instruct

# GPU
BAYMAX_USE_LLAMA_CPP=1
BAYMAX_GPU_LAYERS=99999
LLAMA_CUBLAS=1
CUDA_VISIBLE_DEVICES=0
BAYMAX_CUDA_DEVICE=0
BAYMAX_FAISS_GPU=1
