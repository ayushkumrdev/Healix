# Healix / Baymax.v1 ignore rules

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Test, type-checker, linter caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter checkpoints
.ipynb_checkpoints/

# Environment / secrets — never commit the real .env (see .env.example)
.env
.env.*
!.env.example

# Editor / agent tooling
.claude/

# Virtual environments
.venv/
venv/
env/

# Build artifacts
build/
dist/
*.egg-info/

# OS-specific files
.DS_Store
Thumbs.db

# Logs and temp
*.tmp
*.log
logs/

# Data and artifacts (large files)
artifacts/
data/
datasets/
*.gguf
*.pkl
*.faiss

# Streamlit local files
.streamlit/

